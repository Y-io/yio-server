// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户
model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String?
  emailVerified DateTime? @map("email_verified")

  password String @db.VarChar

  roles         RolesOnUsers[]
  organizations OrganizationsOnUsers[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("users")
}

model RolesOnUsers {
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@id([userId, roleId])
  @@map("role__user")
}

// 角色
model Role {
  id String @id @default(uuid())

  name String

  permissions PermissionsOnRoles[]

  users RolesOnUsers[]

  @@map("roles")
}

// 角色与权限关联表
model PermissionsOnRoles {
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id])
  roleId       String     @map("role_id")

  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String   @map("assigned_by")

  @@id([roleId, permissionId])
  @@map("permission__role")
}

// 权限
model Permission {
  id String @id @default(uuid())

  identify String @unique

  name   String
  action String?
  roles  PermissionsOnRoles[]

  @@map("permissions")
}

// 组织
model Organization {
  id   String @id @default(uuid())
  name String

  users OrganizationsOnUsers[]

  parentId String?
  parent   Organization?  @relation("ParentOrganizations", fields: [parentId], references: [id])
  children Organization[] @relation("ParentOrganizations")

  @@map("organizations")
}

// 用户与组织关联表
model OrganizationsOnUsers {
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  @@id([userId, organizationId])
  @@map("organization__user")
}
