    "ms": "^2.1.3",
    "murlock": "^2.0.1",
    "nest-winston": "^1.9.4",
    "nestjs-i18n": "^10.4.0",
    "nestjs-throttler-storage-redis": "^0.4.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.2",
